# ============================================================
# CONEXAO WPPConnect
# ============================================================

# Nome da sessao local do WPPConnect
WPP_SESSION_NAME=personalize-wppconnect

# false = conecta no WhatsApp Business real
# true = usa o simulador no terminal
MOCK_MODE=false

# false = abre o Chrome visivel
# true = executa em modo invisivel/headless
WPP_HEADLESS=false


# ============================================================
# COMANDOS E RESTRICAO DE TESTE
# ============================================================

# Habilita /reset, /reiniciar e /resetarsys
ENABLE_TEST_COMMANDS=true

# /resetarsys limpa todo o ambiente de teste:
# - sessoes, leads e identidades;
# - etiquetas operacionais aplicadas;
# - notas dos contatos rastreados;
# - contador de pedidos.
# Depois do reset, o proximo pedido volta ao ORDER_NUMBER_START.

# Durante os testes, responde apenas estes numeros.
# Vazio = atende qualquer contato.
ALLOWED_CLIENT_NUMBERS=31971386091

# Use quando quiser liberar diretamente um identificador @lid.
ALLOWED_CHAT_IDS=

# Relaciona o identificador LID ao numero real.
LID_NUMBER_MAP=18885055098907@lid=31971386091


# ============================================================
# BUFFER DE MENSAGENS RECEBIDAS
# ============================================================

BUFFER_MS=8000
MULTI_MESSAGE_BUFFER_MS=8000
MEASURE_BUFFER_MS=8000
ART_BUFFER_MS=8000
ADDRESS_BUFFER_MS=8000
PANTONE_BUFFER_MS=8000
OBSERVATION_BUFFER_MS=9000
CITY_BUFFER_MS=2500
INTERACTIVE_BUFFER_MS=350


# ============================================================
# EXPERIENCIA DE RESPOSTA
# ============================================================

MIN_REPLY_DELAY_MS=1800
MAX_REPLY_DELAY_MS=4200
ENABLE_TYPING=true
TYPING_MIN_MS=650
TYPING_MAX_MS=1600
TYPING_CHARS_PER_SECOND=45


# ============================================================
# MENSAGENS NAO LIDAS
# ============================================================

ENABLE_UNREAD_BOOTSTRAP=true
UNREAD_BOOTSTRAP_DELAY_MS=6000
UNREAD_BOOTSTRAP_MAX_CHATS=30
UNREAD_BOOTSTRAP_MAX_MESSAGES_PER_CHAT=8


# ============================================================
# ASSETS DO FLUXO
# ============================================================

ASSETS_DIR=assets

BEM_VINDOS_IMAGE_BASENAME=capa_bem_vindos
BEM_VINDOS_LINK_URL=https://personalizeseuambiente.com.br/bem-vindos

MOSTRUARIO_LETREIRO_IMAGE_BASENAME=capa-mostruario
MOSTRUARIO_LINK_URL=https://personalizeseuambiente.com.br/mostruario-letreiros

ASSET_TABELA_CORES_BASENAME=tabela-cores-v2
ASSET_TABELA_ESPESSURA_BASENAME=tabela-espessura
ASSET_TABELA_PROFUNDIDADE_BASENAME=tabela-profundidade-3mm


# ============================================================
# DADOS DA EMPRESA
# ============================================================

BUSINESS_NAME=Personalize
SELLER_NAME=Vendedor Personalize


# ============================================================
# FINALIZACAO DO ATENDIMENTO
# ============================================================

STOP_NON_LETTERING_FLOW=true
ENABLE_CONTACT_NOTES=true

# Primeiro numero usado em cada ambiente de teste.
# /resetarsys zera o contador e o proximo pedido volta para este valor.
ORDER_NUMBER_START=70001

# Depois da conclusao, mensagem manual do vendedor ou etiqueta de vendedor,
# o bot permanece silencioso por 72 horas.
BOT_REENTRY_AFTER_HOURS=72

# Detecta somente mensagens manuais de texto enviadas pelo numero conectado.
# Imagem, lista, botao, documento, evento vazio e URL automatica nao assumem atendimento.
DETECT_MANUAL_SELLER_MESSAGES=true

# Tempo usado pelo rastreador interno para reconhecer mensagens do proprio bot.
BOT_OUTBOUND_TRACKER_TTL_MS=45000


# ============================================================
# ETIQUETAS TEXTUAIS DO WHATSAPP BUSINESS
# ============================================================

ENABLE_CONTACT_LABELS=true

# Estas sao as etiquetas com texto visivel na lista de conversas.
# Orçamento letreiros precisa ser ROXA.
SERVICE_LABEL_LETREIRO=Orçamento letreiros
SERVICE_LABEL_LETREIRO_COLOR=purple

# Cor roxa usada para localizar a cor na paleta real do WhatsApp.
# O valor precisa de aspas porque # inicia comentario em arquivos .env.
SERVICE_LABEL_LETREIRO_COLOR_HEX="#7f66ff"

# Fallback usado somente quando o WhatsApp nao devolve sua paleta.
# Evita criar a etiqueta sem colorIndex, o que anteriormente a deixava verde.
SERVICE_LABEL_LETREIRO_COLOR_INDEX=5

SERVICE_LABEL_PLOTAGEM=Plotagens
SERVICE_LABEL_PLOTAGEM_COLOR=gray

SERVICE_LABEL_OUTROS=Outros
SERVICE_LABEL_OUTROS_COLOR=red

SUPPORT_LABEL_NAME=Suporte
SUPPORT_LABEL_COLOR=red

# Somente etiquetas operacionais podem substituir umas as outras.
SERVICE_LABEL_REPLACE_GROUP=Orçamento letreiros,Plotagens,Outros,Suporte

# Se existir apenas uma versao com a cor errada, cria a correta ao lado dela.
# A versao errada NAO e apagada antes da migracao dos contatos.
RECREATE_MISMATCHED_OPERATIONAL_LABELS=true

# Depois de confirmar a etiqueta canonica no contato, remove o vinculo antigo.
# A duplicada global so e apagada quando o WhatsApp informar count=0 e todos
# os contatos rastreados estiverem confirmados na etiqueta correta.
CLEANUP_DUPLICATE_OPERATIONAL_LABELS=true


# ============================================================
# RESPONSABILIDADE DOS VENDEDORES
# ============================================================

# O handoff por etiqueta exige nome E cor corretos:
# Adriano = verde
# Ana = azul
# Dudu = amarela
# Uma etiqueta com nome correto e cor errada e ignorada.
SELLER_NAMES=Adriano;Ana;Dudu

# Quando um vendedor recebe um cliente, a conversa e marcada como nao lida.
# Essa e a bolinha verde mostrada pelo WhatsApp.
MARK_SELLER_CLIENT_UNREAD=true


# ============================================================
# BANCO E RECONCILIACAO
# ============================================================

# Evita consultar as etiquetas do mesmo contato repetidamente.
LABEL_OBSERVATION_MIN_INTERVAL_MS=30000

# Pequena pausa entre clientes durante restauracoes em massa.
LABEL_RECONCILE_DELAY_MS=120

# Confere o banco e restaura vinculos a cada 5 minutos.
# A bolinha de vendedor e marcada somente uma vez por execucao.
# Use 0 para desativar.
LABEL_RECONCILE_INTERVAL_MS=300000

DETECT_MANUAL_CONTACT_LABELS=true
STORE_MANUAL_CONTACT_LABELS=true


# ============================================================
# COMPATIBILIDADE
# ============================================================

AWAITING_QUOTE_LABEL_NAME=Orçamento letreiros
AWAITING_QUOTE_LABEL_COLOR=purple
