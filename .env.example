# Nome da sessao local do WPPConnect
WPP_SESSION_NAME=personalize-wppconnect

# Modo real: false. O bot conecta no WhatsApp Business via WPPConnect.
# Modo terminal/simulador: true. Nao use para teste real com WhatsApp.
MOCK_MODE=false

# false = abre Chrome visivel com WhatsApp Web para ler QR Code
# true = roda invisivel/headless e mostra QR no terminal
WPP_HEADLESS=false

# Comandos de teste: /reset e /resetarsys. Desative em produção.
ENABLE_TEST_COMMANDS=true

# Enquanto estiver em teste, responda somente este(s) numero(s).
# Vazio = atende qualquer contato.
ALLOWED_CLIENT_NUMBERS=31971386091
# Use ALLOWED_CHAT_IDS se o WhatsApp retornar @lid e o numero nao for identificavel no log.
ALLOWED_CHAT_IDS=
# Mapeia LID -> numero real para whitelist e identificação do teste.
# Exemplo real do teste atual:
LID_NUMBER_MAP=18885055098907@lid=31971386091

# Delays para deixar o bot menos instantaneo no WPPConnect
MIN_REPLY_DELAY_MS=1800
MAX_REPLY_DELAY_MS=4200
BUFFER_MS=4500

# Ao iniciar conectado, tenta puxar mensagens nao lidas que chegaram enquanto o bot estava desligado
ENABLE_UNREAD_BOOTSTRAP=true
UNREAD_BOOTSTRAP_DELAY_MS=6000
UNREAD_BOOTSTRAP_MAX_CHATS=30
UNREAD_BOOTSTRAP_MAX_MESSAGES_PER_CHAT=8

# Assets do mostruario de letreiro
ASSETS_DIR=assets
MOSTRUARIO_LETREIRO_IMAGE_BASENAME=Mostruario_Letreiro
# Use quando o PDF ficar online ativo
MOSTRUARIO_LETREIRO_PDF_URL=
# Opcional: caminho local do PDF caso queira enviar arquivo em vez de link
MOSTRUARIO_LETREIRO_PDF_PATH=

# Dados da Personalize
BUSINESS_NAME=Personalize
SELLER_NAME=Vendedor Personalize

# Quando o cliente nao for fluxo de letreiro, o sistema para e salva lead
STOP_NON_LETTERING_FLOW=true

# Tenta colocar nota no contato Business quando suportado pela sessao/WA-JS
ENABLE_CONTACT_NOTES=true

# Etiquetas de tipo de atendimento.
# O bot tenta remover as etiquetas desse grupo e aplicar apenas a correta.
ENABLE_CONTACT_LABELS=true
SERVICE_LABEL_LETREIRO=Orçamento letreiro
SERVICE_LABEL_LETREIRO_COLOR=green
SERVICE_LABEL_PLOTAGEM=Plotagens
SERVICE_LABEL_PLOTAGEM_COLOR=gray
SERVICE_LABEL_OUTROS=Outros
SERVICE_LABEL_OUTROS_COLOR=red
SERVICE_LABEL_REPLACE_GROUP=Orçamento letreiro,Plotagens,Outros

# Mantido por compatibilidade: hoje aponta para a etiqueta verde de letreiro
AWAITING_QUOTE_LABEL_NAME=Orçamento letreiro
AWAITING_QUOTE_LABEL_COLOR=green
