# ============================================================
# CONEXAO WPPConnect
# ============================================================

# Nome da sessao local do WPPConnect
WPP_SESSION_NAME=personalize-wppconnect

# false = conecta no WhatsApp Business real
# true = usa o simulador no terminal
MOCK_MODE=false

# false = abre o Chrome visivel
# true = executa em modo invisivel/headless
WPP_HEADLESS=false


# ============================================================
# COMANDOS E RESTRICAO DE TESTE
# ============================================================

# Habilita /reset, /reiniciar e /resetarsys
ENABLE_TEST_COMMANDS=true

# Durante os testes, responde apenas estes numeros.
# Vazio = atende qualquer contato.
ALLOWED_CLIENT_NUMBERS=31971386091

# Use quando quiser liberar diretamente um identificador @lid.
ALLOWED_CHAT_IDS=

# Relaciona o identificador LID ao numero real.
LID_NUMBER_MAP=18885055098907@lid=31971386091


# ============================================================
# BUFFER DE MENSAGENS RECEBIDAS
# ============================================================

# Espera comum para juntar mensagens consecutivas do cliente.
BUFFER_MS=8000

# Coletas que podem ser enviadas em varias mensagens.
MULTI_MESSAGE_BUFFER_MS=8000

# Tempo especifico para juntar largura, altura e descricoes.
MEASURE_BUFFER_MS=8000

# Tempo para juntar texto, imagem e arquivo da arte.
ART_BUFFER_MS=8000

# Tempo para juntar as partes do endereco.
ADDRESS_BUFFER_MS=8000

# Tempo para juntar codigo, descricao e referencia Pantone.
PANTONE_BUFFER_MS=8000

# Tempo para juntar observacoes escritas pelo cliente.
OBSERVATION_BUFFER_MS=9000

# Cidade normalmente e uma resposta curta.
CITY_BUFFER_MS=2500

# Cliques em listas e botoes devem ser processados rapidamente.
INTERACTIVE_BUFFER_MS=350


# ============================================================
# EXPERIENCIA DE RESPOSTA
# ============================================================

# Mantidos para respostas avulsas.
# Em conjuntos de baloes, o sistema ignora esses delays e envia
# todas as mensagens seguidas com uma unica digitacao.
# O bloco inicial de boas-vindas e a excecao: sai sem digitacao.
MIN_REPLY_DELAY_MS=1800
MAX_REPLY_DELAY_MS=4200

# Exibe "digitando..." antes das respostas comuns.
ENABLE_TYPING=true

# Duracao minima e maxima da digitacao.
TYPING_MIN_MS=650
TYPING_MAX_MS=1600

# Velocidade usada para calcular o tempo de digitacao.
TYPING_CHARS_PER_SECOND=45


# ============================================================
# MENSAGENS NAO LIDAS
# ============================================================

# Ao iniciar, tenta recuperar mensagens recebidas enquanto
# o sistema estava desligado.
ENABLE_UNREAD_BOOTSTRAP=true

UNREAD_BOOTSTRAP_DELAY_MS=6000
UNREAD_BOOTSTRAP_MAX_CHATS=30
UNREAD_BOOTSTRAP_MAX_MESSAGES_PER_CHAT=8


# ============================================================
# ASSETS DO FLUXO
# ============================================================

ASSETS_DIR=assets

# Imagem enviada logo depois da saudacao.
# A URL crua e usada como legenda/titulo da propria imagem.
# Nao e enviado um segundo balao com o link.
BEM_VINDOS_IMAGE_BASENAME=capa_bem_vindos
BEM_VINDOS_LINK_URL=https://personalizeseuambiente.com.br/bem-vindos

# Imagem da capa do mostruario.
# A URL crua e usada como legenda/titulo da propria imagem.
# Nao e enviado um segundo balao com o link.
MOSTRUARIO_LETREIRO_IMAGE_BASENAME=capa-mostruario
MOSTRUARIO_LINK_URL=https://personalizeseuambiente.com.br/mostruario-letreiros

# Imagens das tabelas.
ASSET_TABELA_CORES_BASENAME=tabela-cores-v2
ASSET_TABELA_ESPESSURA_BASENAME=tabela-espessura
ASSET_TABELA_PROFUNDIDADE_BASENAME=tabela-profundidade-3mm


# ============================================================
# DADOS DA EMPRESA
# ============================================================

BUSINESS_NAME=Personalize

# Mantido apenas por compatibilidade com partes antigas.
SELLER_NAME=Vendedor Personalize


# ============================================================
# FINALIZACAO DO ATENDIMENTO
# ============================================================

# O fluxo de plotagem e outros tambem coleta as informacoes.
# Ao finalizar, os dados ficam salvos na nota do contato.
STOP_NON_LETTERING_FLOW=true

# Salva todos os dados coletados na nota do contato Business.
ENABLE_CONTACT_NOTES=true


# ============================================================
# LISTAS / ETIQUETAS DO WHATSAPP BUSINESS
# ============================================================

ENABLE_CONTACT_LABELS=true

# Detecta etiquetas que ja estavam no contato e nao pertencem ao
# grupo gerenciado pelo bot. Funciona com etiquetas novas criadas
# manualmente, sem precisar cadastrar nomes de vendedores no codigo.
DETECT_MANUAL_CONTACT_LABELS=true

# Salva na sessao os nomes, IDs e cores das etiquetas manuais detectadas.
STORE_MANUAL_CONTACT_LABELS=true

# Cores atualmente reservadas aos vendedores:
# Adriano = green
# Aninha = blue
# Carlos = yellow
# Essas etiquetas e qualquer etiqueta nova criada manualmente sao preservadas.

SERVICE_LABEL_LETREIRO=Orçamento letreiro
SERVICE_LABEL_LETREIRO_COLOR=purple

SERVICE_LABEL_PLOTAGEM=Plotagens
SERVICE_LABEL_PLOTAGEM_COLOR=gray

SERVICE_LABEL_OUTROS=Outros
SERVICE_LABEL_OUTROS_COLOR=red

# O nome foi mantido por compatibilidade, mas o bot nao substitui nem remove
# nenhuma etiqueta. Este grupo serve apenas para distinguir etiquetas de
# servico das etiquetas manuais ao registrar os dados do contato.
SERVICE_LABEL_REPLACE_GROUP=Orçamento letreiro,Plotagens,Outros


# ============================================================
# COMPATIBILIDADE
# ============================================================

AWAITING_QUOTE_LABEL_NAME=Orçamento letreiro
AWAITING_QUOTE_LABEL_COLOR=purple
