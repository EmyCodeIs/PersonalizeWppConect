# ============================================================
# CONEXAO WPPConnect — TESTE LOCAL WINDOWS
# ============================================================
WPP_SESSION_NAME=personalize-wppconnect
MOCK_MODE=false
WPP_HEADLESS=false

# No Windows, execute apenas npm start. O Chrome abre normalmente na tela.
# O acesso do vendedor pelo navegador será configurado somente na VPS.
SESSION_ACCESS_AUTO_START=false

# ============================================================
# SETOR DE ETIQUETAS — INDEPENDENTE DO PRE-ATENDIMENTO
# ============================================================
LABEL_MAINTENANCE_ENABLED=true
LABEL_MAINTENANCE_REQUIRE_COLOR=true
LABEL_MAINTENANCE_AUTO_REMOVE_DUPLICATES=true
LABEL_MAINTENANCE_CHECK_ATTEMPTS=3
LABEL_MAINTENANCE_CHECK_DELAY_MS=1800
LABEL_MAINTENANCE_RETRY_MS=15000

# ============================================================
# COMANDOS E RESTRICAO DE TESTE
# ============================================================
ENABLE_TEST_COMMANDS=true
ALLOWED_CLIENT_NUMBERS=31971386091
ALLOWED_CHAT_IDS=18885055098907@lid
LID_NUMBER_MAP=18885055098907@lid=31971386091

# ============================================================
# MEMORIA CURTA, CACHE E MANUTENCAO
# ============================================================
FLOW_SESSION_TTL_HOURS=24
COMPLETED_SESSION_TTL_HOURS=24
MAINTENANCE_INTERVAL_MS=900000
RUNTIME_CACHE_MAX_ENTRIES=5000
BOT_ACTIVITY_TTL_DAYS=30

# ============================================================
# FILA GLOBAL DE ATENDIMENTO
# ============================================================
QUEUE_MAX_UNITS=4
MAX_CONCURRENT_CHATS=2
MAX_QUEUE_SIZE=40
CHAT_PROCESS_TIMEOUT_MS=45000

# ============================================================
# HANDOFF HUMANO / ETIQUETAS DE VENDEDOR
# ============================================================
SELLER_LABEL_BLOCKING_ENABLED=true
SELLER_LABEL_RULES=Adriano=#8FD0A8;Ana=#00A4F2;Emy=#7FE51F;C. Eduardo=#FEB100
HUMAN_BLOCK_HOURS=24

# ============================================================
# BUFFER DE MENSAGENS RECEBIDAS
# ============================================================
BUFFER_MS=8000
MULTI_MESSAGE_BUFFER_MS=8000
MEASURE_BUFFER_MS=8000
ART_BUFFER_MS=12000
ADDRESS_BUFFER_MS=8000
PANTONE_BUFFER_MS=8000
OBSERVATION_BUFFER_MS=9000
SUPPORT_BUFFER_MS=9000
CITY_BUFFER_MS=2500
INTERACTIVE_BUFFER_MS=350

# ============================================================
# EXPERIENCIA DE RESPOSTA
# ============================================================
MIN_REPLY_DELAY_MS=1800
MAX_REPLY_DELAY_MS=4200
ENABLE_TYPING=true
TYPING_MIN_MS=650
TYPING_MAX_MS=1600
TYPING_CHARS_PER_SECOND=45

# ============================================================
# MENSAGENS NAO LIDAS — TESTE LOCAL SEGURO
# ============================================================
# Continue false no seu teste atual para não recuperar conversas antigas.
ENABLE_UNREAD_BOOTSTRAP=false
UNREAD_BOOTSTRAP_DELAY_MS=6000
UNREAD_BOOTSTRAP_ATTEMPTS=3
UNREAD_BOOTSTRAP_RETRY_DELAY_MS=2500
UNREAD_BOOTSTRAP_MAX_CHATS=30
UNREAD_BOOTSTRAP_MAX_MESSAGES_PER_CHAT=8
UNREAD_RECOVERY_HISTORY_LIMIT=120
UNREAD_BOOTSTRAP_MAX_AGE_HOURS=24

# ============================================================
# ASSETS DO FLUXO
# ============================================================
ASSETS_DIR=assets
BEM_VINDOS_IMAGE_BASENAME=capa_bem_vindos
BEM_VINDOS_LINK_URL=https://personalizeseuambiente.com.br/bem-vindos
MOSTRUARIO_LETREIRO_IMAGE_BASENAME=capa-mostruario
MOSTRUARIO_LINK_URL=https://personalizeseuambiente.com.br/mostruario-letreiros
ASSET_TABELA_CORES_BASENAME=tabela-cores-v2
ASSET_TABELA_ESPESSURA_BASENAME=tabela-espessura
ASSET_TABELA_PROFUNDIDADE_BASENAME=tabela-profundidade-3mm

# ============================================================
# DADOS DA EMPRESA
# ============================================================
BUSINESS_NAME=Personalize
SELLER_NAME=Vendedor Personalize

# ============================================================
# FINALIZACAO DO ATENDIMENTO
# ============================================================
STOP_NON_LETTERING_FLOW=true
ENABLE_CONTACT_NOTES=true

# ============================================================
# LISTAS / ETIQUETAS DO WHATSAPP BUSINESS
# ============================================================
ENABLE_CONTACT_LABELS=true
DETECT_MANUAL_CONTACT_LABELS=true
STORE_MANUAL_CONTACT_LABELS=true
SERVICE_LABEL_LETREIRO=Orçamento letreiros
SERVICE_LABEL_LETREIRO_COLOR=purple
SERVICE_LABEL_PLOTAGEM=Plotagens
SERVICE_LABEL_PLOTAGEM_COLOR=gray
SERVICE_LABEL_OUTROS=Outros
SERVICE_LABEL_OUTROS_COLOR=red
SERVICE_LABEL_SUPPORT=Suporte
SERVICE_LABEL_SUPPORT_COLOR=red
SERVICE_LABEL_REPLACE_GROUP=Orçamento letreiros,Plotagens,Outros

# ============================================================
# COMPATIBILIDADE
# ============================================================
AWAITING_QUOTE_LABEL_NAME=Orçamento letreiros
AWAITING_QUOTE_LABEL_COLOR=purple
