{
  "name": "personalize-wppconnect-cliente-flow",
  "version": "0.7.3",
  "description": "Port local do fluxo cliente da Personalize para WPPConnect, com criação verificada das listas reais do WhatsApp Business por cor, preservação das listas manuais, recuperação imediata das sessões ativas após reinício, links em legendas de imagem e finalização em nota do contato.",
  "main": "src/start-with-required-labels.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/start-with-required-labels.js",
    "dev": "node src/start-with-required-labels.js",
    "test": "npm run check && npm run test:readiness && npm run test:handoff && npm run test:exclusive-labels && npm run test:reset-handoff && npm run test:reset-labels && npm run test:commands && npm run test:catalog && npm run test:env && npm run test:vps-browser",
    "check": "node scripts/check-syntax.js",
    "test:flow": "node scripts/test-flow.js",
    "test:readiness": "node scripts/test-readiness.js",
    "test:handoff": "node scripts/test-handoff-readiness.js",
    "test:exclusive-labels": "node scripts/test-exclusive-service-labels.js",
    "test:reset-handoff": "node scripts/test-reset-command-handoff.js",
    "test:reset-labels": "node scripts/test-reset-label-preservation.js",
    "test:commands": "node scripts/test-command-access.js",
    "test:catalog": "node scripts/test-catalog-mostruario.js",
    "test:env": "node scripts/test-env-examples.js",
    "test:vps-browser": "node scripts/test-vps-browser.js",
    "test:labels": "node scripts/test-labels.js",
    "tokens:cache:check": "node scripts/clean-token-cache.js",
    "tokens:cache:clean": "node scripts/clean-token-cache.js --apply",
    "session:access": "bash scripts/start-session-access.sh",
    "session:access:stop": "bash scripts/stop-session-access.sh",
    "session:access:health": "bash scripts/session-access-health.sh",
    "session:access:watch": "bash scripts/watch-session-access.sh",
    "session:access:install:ubuntu": "bash scripts/install-session-access-ubuntu.sh",
    "vps:backup": "bash scripts/backup-vps-state.sh",
    "vps:preflight": "bash scripts/vps-preflight.sh",
    "vps:configure-nginx": "bash scripts/configure-nginx-access.sh",
    "vps:start": "bash scripts/start-vps-whatsapp.sh"
  },
  "dependencies": {
    "@novnc/novnc": "^1.5.0",
    "@wppconnect-team/wppconnect": "^2.2.1",
    "dotenv": "^17.2.3",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "devDependencies": {}
}
