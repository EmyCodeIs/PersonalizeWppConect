{
  "name": "personalize-wppconnect-cliente-flow",
  "version": "0.7.3",
  "description": "Port local do fluxo cliente da Personalize para WPPConnect, com criação verificada das listas reais do WhatsApp Business por cor, preservação das listas manuais, recuperação imediata das sessões ativas após reinício, catálogo nativo e finalização em nota do contato.",
  "main": "src/start-with-required-labels.js",
  "type": "commonjs",
  "scripts": {
    "start": "node src/start-with-required-labels.js",
    "dev": "node src/start-with-required-labels.js",
    "test": "npm run check && npm run test:decision-logs && npm run test:business-config && npm run test:lettering-sequence && npm run test:single-art-flow && npm run test:readiness && npm run test:handoff && npm run test:seller-label-events && npm run test:exclusive-labels && npm run test:service-label-once && npm run test:seller-label-migration && npm run test:reset-handoff && npm run test:reset-labels && npm run test:commands && npm run test:catalog && npm run test:token-cache && npm run test:token-runtime && npm run test:browser-cache && npm run test:env && npm run storage:test && npm run test:vps-browser",
    "check": "node scripts/check-syntax.js",
    "test:decision-logs": "node scripts/test-decision-logs.js",
    "test:flow": "node scripts/test-flow.js",
    "test:business-config": "node scripts/test-current-business-config.js",
    "test:lettering-sequence": "node scripts/test-lettering-flow-sequence.js",
    "test:single-art-flow": "node scripts/test-single-art-flow.js",
    "test:readiness": "node scripts/test-readiness.js",
    "test:handoff": "node scripts/test-handoff-readiness.js",
    "test:seller-label-events": "node scripts/test-seller-label-events.js",
    "test:exclusive-labels": "node scripts/test-exclusive-service-labels.js",
    "test:service-label-once": "node scripts/test-service-label-once.js",
    "test:seller-label-migration": "node scripts/test-seller-label-migration.js",
    "test:reset-handoff": "node scripts/test-reset-command-handoff.js",
    "test:reset-labels": "node scripts/test-reset-label-preservation.js",
    "test:commands": "node scripts/test-command-access.js",
    "test:catalog": "node scripts/test-catalog-mostruario.js",
    "test:token-cache": "node scripts/test-token-cache-safety.js",
    "test:token-runtime": "node scripts/test-token-cache-runtime.js",
    "test:env": "node scripts/test-env-examples.js",
    "test:vps-browser": "node scripts/test-vps-browser.js",
    "test:labels": "node scripts/test-labels.js",
    "labels:sellers:audit": "node scripts/migrate-seller-labels.js",
    "labels:sellers:migrate": "node scripts/migrate-seller-labels.js --apply --confirm=MIGRAR_ETIQUETAS_VENDEDORES",
    "tokens:cache:check": "node scripts/clean-token-cache-safe.js",
    "tokens:cache:clean": "node scripts/clean-token-cache-safe.js --apply",
    "session:access": "bash scripts/start-session-access.sh",
    "session:access:stop": "bash scripts/stop-session-access.sh",
    "session:access:health": "bash scripts/session-access-health.sh",
    "session:access:watch": "bash scripts/watch-session-access.sh",
    "session:access:install:ubuntu": "bash scripts/install-session-access-ubuntu.sh",
    "vps:backup": "bash scripts/backup-vps-state.sh",
    "vps:preflight": "bash scripts/vps-preflight-admin-wrapper.sh",
    "vps:configure-nginx": "bash scripts/configure-nginx-access.sh",
    "vps:start": "bash scripts/start-vps-whatsapp.sh",
    "storage:init": "node scripts/init-secure-storage.js",
    "storage:test": "node scripts/test-secure-storage.js",
    "vps:prepare": "node scripts/prepare-vps-env.js",
    "vps:deploy": "bash scripts/deploy-vps-ready.sh",
    "test:browser-cache": "node scripts/test-browser-cache-runtime.js",
    "storage:seal-legacy": "node scripts/seal-legacy-data.js --apply"
  },
  "dependencies": {
    "@novnc/novnc": "^1.5.0",
    "@wppconnect-team/wppconnect": "^2.2.1",
    "dotenv": "^17.2.3",
    "sharp": "^0.35.3",
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=22 <25"
  }
}
